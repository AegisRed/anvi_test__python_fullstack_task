{
  "name": "daily-vibe-check",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "api": "node server/index.js",
    "dev:all": "concurrently \"npm run api\" \"npm run dev\"",
